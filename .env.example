# Copiar a .env y ajustar (no subir .env al repositorio)

MYSQL_ROOT_PASSWORD=devroot
MYSQL_DATABASE=instituto
MYSQL_USER=instituto
MYSQL_PASSWORD=instituto

MYSQL_PORT=3306
WEB_PORT=8080
PMA_PORT=8081

# Fecha de corte opcional para cálculo de saldo_cc (YYYY-MM-DD)
# Ejemplo: SALDO_CORTE_DESDE=2023-01-01
SALDO_CORTE_DESDE=2026-01-01

# Factura electrónica (Gesis / AFIP) — usuario de integración del instituto
# Lo crea el admin de Gesis; ver DEV_INTEGRATION.md
# GESIS_FE_URL=https://servicios.gesis2.com
# GESIS_FE_EMAIL=facturacion@tu-instituto.com
# GESIS_FE_PASSWORD=clave_del_usuario_integracion
# Homologación (recomendado al probar): no poner true en producción hasta go-live
# GESIS_FE_PRODUCTION=false
# GESIS_FE_PTO_VTA=1
# GESIS_FE_CBTE_TIPO=11